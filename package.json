{
  "name": "tier2tickets-relay",
  "version": "1.0.0",
  "description": "Cloudflare Worker that impersonates an osTicket helpdesk so Tier2Tickets / Helpdesk Buttons can create tickets in Gorelo.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.7.2",
    "vitest": "2.1.9",
    "wrangler": "^3.95.0"
  }
}
